# XDG base dirs
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export ZSH_CACHE_DIR="$XDG_CACHE_HOME/zsh"
case $(uname) in
Linux)
  XDG_RUNTIME_DIR=/run/user/$(id -u)
  ;;
Darwin)
  XDG_RUNTIME_DIR=$(getconf DARWIN_USER_TEMP_DIR)
  ;;
esac

# Default programs
export EDITOR="nvim"
export MANPAGER="nvim +Man!"

# fix java on mac
if [[ "$(uname)" == "Darwin" ]]; then
  export JAVA_HOME=/opt/homebrew/opt/java
fi

# go
export GOPATH="$XDG_DATA_HOME/go"

# npm
export NPM_CONFIG_USERCONFIG=$XDG_CONFIG_HOME/npm/npmrc

# bitwarden
if (($+commands[flatpak])) && flatpak info com.bitwarden.desktop &>/dev/null; then
  export BITWARDEN_SSH_AUTH_SOCK="$HOME/.var/app/com.bitwarden.desktop/data/.bitwarden-ssh-agent.sock"
else
  export BITWARDEN_SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/bitwarden-ssh-agent.sock"
fi

# docker
export DOCKER_CONFIG="$XDG_CONFIG_HOME"/docker

# skills.sh
export DISABLE_TELEMETRY=1

# nvm
export NVM_DIR="$XDG_DATA_HOME/nvm"
export NVM_LAZY_LOAD=true

# ssh
case $(uname) in
Linux)
  export SSH_AUTH_SOCK="$BITWARDEN_SSH_AUTH_SOCK"
  ;;
Darwin)
  export SSH_AUTH_SOCK="$HOME/.bitwarden-ssh-agent.sock"
  ;;
esac

# path
path+=("$HOME/.local/bin")
path+=("{{ .chezmoi.workingTree }}/scripts")
path+=("$GOPATH/bin")
path+=("$HOME/.local/share/npm/bin")
export path
