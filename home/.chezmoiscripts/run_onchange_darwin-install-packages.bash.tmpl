#!/usr/bin/env bash

{{ if ne .chezmoi.os "darwin" -}}
exit 0
{{ end -}}

HOMEBREW_NO_AUTO_UPDATE=1
brew bundle --file=/dev/stdin --no-upgrade --quiet <<EOF
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
